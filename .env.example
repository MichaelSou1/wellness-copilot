# =========================
# LLM / 在线能力（必填）
# =========================
# 所有节点（Planner / Critic / 各专家 / Aggregator / ReplanJudge）共用一个 OpenAI 兼容 API。
# 推荐直接走 OpenAI 官方接口 + 当前最强模型（GPT-5.5 / GPT-5.5 Pro）。
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-5.5

# 调用模式：OpenAI Responses API（推荐）。若服务商只兼容 Chat Completions 则改为 chat_completions
LLM_API_MODE=responses
LLM_OUTPUT_VERSION=responses/v1

# 是否禁用思考模式（例如火山引擎的部分 GLM 模型，可通过此项关闭 thinking 降低时延）
LLM_DISABLE_THINKING=false

# =========================
# Judge LLM（L5 端到端评测专用，可选）
# =========================
# scripts/evaluate_output.py 用一个独立的 LLM 给最终回答打 1-5 分（relevance/completeness/
# safety/personalization/coherence 五维）。强烈建议跟主对话模型用不同厂商，避免自评膨胀
# （让 GPT 给 GPT 打分会系统性偏高）。
#
# 行为：
#   • JUDGE_BASE_URL 留空 → 自动 fallback 到上面的 LLM_* 配置，脚本会打 WARN
#     提示「分数会偏高，建议设置独立 judge model」。
#   • JUDGE_BASE_URL 设置后 → 走 OpenAI-compatible /chat/completions HTTP 接口
#     （脚本内置 _HttpJudgeLLM，绕过 openai/langchain_openai SDK 版本差异）。
#   • JUDGE_API_KEY / JUDGE_MODEL 单独留空时，会分别 fallback 到 LLM_API_KEY / LLM_MODEL。
#
# 推荐组合：主对话用 GPT-5.5，Judge 用 DeepSeek-v3 / Claude / Gemini 等异源模型。
JUDGE_BASE_URL=
JUDGE_API_KEY=
JUDGE_MODEL=

# =========================
# 项目数据路径（可选，均为默认值）
# =========================
# 语义记忆：跨会话稳定画像（体征/伤病/偏好/目标/心理）
PROFILE_STORE_PATH=profile_store.json
# 情节记忆：跨 thread 的"上轮发生了什么"摘要（每用户最近 20 条，Critic 写、TurnStart 读）
EPISODE_STORE_PATH=episode_store.json
# 情节记忆语义召回：最近 2 条 + 语义相关 top-k；模型复用 RAG embedding
EPISODE_SEMANTIC_RETRIEVAL_ENABLED=true
EPISODE_EMBED_ON_WRITE_ENABLED=false
EPISODE_SEMANTIC_MIN_COUNT=8
EPISODE_SEMANTIC_TOP_K=3
# EPISODE_INDEX_DIR=~/.health_guide_indices/episodes
# 跨进程会话恢复：user_id -> 上次 thread_id 映射（main.py 启动时读，问是否续会话）
SESSION_STORE_PATH=session_store.json
# LangGraph checkpoint / observability / local actuation logs
SQLITE_DB_PATH=checkpoints.db
OBSERVABILITY_DB_PATH=observability.db
HEALTH_LOGS_DB_PATH=health_logs.db
DEFAULT_TIMEZONE=Asia/Shanghai
# 分层知识库根目录
KNOWLEDGE_BASE_DIR=knowledge_base

# 各 agent 的 KB 子目录名（默认与 agent 同名；通常不需要改）
# KNOWLEDGE_BASE_TRAINER_SUBDIR=trainer
# KNOWLEDGE_BASE_NUTRITIONIST_SUBDIR=nutritionist
# KNOWLEDGE_BASE_PSYCHOLOGIST_SUBDIR=psychologist
# KNOWLEDGE_BASE_SAFETY_SUBDIR=safety

# =========================
# RAG 模型（可选，默认已针对 8GB 显存 + 中英双语语料调优）
# =========================
# 默认 embedding: BAAI/bge-m3（多语言,支持 zh+en,8192 上下文）
# 如需切回中文单语小模型以节省显存,可改为 BAAI/bge-small-zh-v1.5
# 默认 reranker: BAAI/bge-reranker-v2-m3（基于 bge-m3,原生支持中英文,效果优于 bge-reranker-base）
RAG_EMBED_MODEL_NAME=BAAI/bge-m3
RAG_RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3
RAG_DEVICE=auto
RAG_RETRIEVE_TOP_K=12
RAG_FINAL_TOP_K=4
RAG_EMBED_BATCH_SIZE=32
RAG_RERANK_BATCH_SIZE=16
# 主 embedding 模型加载失败时降级回退的小模型（中文单语，~512MB）
RAG_FALLBACK_EMBED_MODEL_NAME=BAAI/bge-small-zh-v1.5
# HuggingFace 模型缓存目录（默认在项目根的 hf_cache/；想统一到全局可改）
# 也支持标准 HF_HOME / HUGGINGFACE_HUB_CACHE 变量，但 RAG_* 优先级更高
# RAG_HF_HOME=/path/to/hf_cache
# RAG_HF_HUB_CACHE=/path/to/hf_cache/hub

# =========================
# 社区 MCP 工具服务器（可选）
# =========================
# 默认全关；显式打开后 main.py 启动时会 spawn 对应 npx 子进程。
# 需要系统已装 Node.js ≥ 18。任一服务器握手失败 → 对应专家退回 RAG-only。
#
# 先跑一次 `bash scripts/setup_mcp_servers.sh` ——
#   • clone USDA MCP（jlfwong 仓库未发 npm）并 npm install + bump @modelcontextprotocol/sdk
#   • 装 medical-mcp 到固定路径 + sed 把 console.log 改成 console.error（修 stdout 污染）
#   • 装 wger-mcp 到固定路径 + sed patch zod schema 的 variations 字段
# 脚本结束会打印需要填到下面三行的 *_SCRIPT_PATH。
MCP_TRAINER_ENABLED=false       # wger（动作百科 5 个公共工具，server 启动需 wger.de 账号）
MCP_NUTRITIONIST_ENABLED=false  # USDA FoodData Central（食物宏量素，60w+ 食品）
MCP_DOCTOR_ENABLED=false        # medical-mcp（FDA/PubMed/WHO/RxNorm/Cochrane/Scholar，10 工具）

# --- Nutritionist (USDA) ---
# 免费 key：https://fdc.nal.usda.gov/api-key-signup（邮箱注册 30s）
USDA_API_KEY=
MCP_USDA_SCRIPT_PATH=

# --- Doctor (medical-mcp) ---
# 无需 key；8 个 REST API 工具开箱即用。
# 另 2 个走 puppeteer 的工具（search-google-scholar / search-medical-databases）
# 需要 Chrome 运行时库，在 hga conda env 内一次性装齐：
#   conda install -y -c conda-forge nspr nss dbus atk-1.0 at-spi2-atk libcups \
#     libxkbcommon xorg-libxcomposite xorg-libxdamage xorg-libxfixes xorg-libxrandr \
#     libgbm pango alsa-lib libdrm xorg-libxshmfence gtk3 xorg-libxext xorg-libxscrnsaver
# mcp_client.py 会自动把 $CONDA_PREFIX/lib 注入到 medical-mcp 子进程的 LD_LIBRARY_PATH。
MCP_MEDICAL_SCRIPT_PATH=

# --- Trainer (wger) ---
# wger MCP 启动时强制要 auth，即便只用 5 个免认证读工具。
# 免费账号 https://wger.de/en/user/registration，登录后在个人页生成 API key。
WGER_API_KEY=
MCP_WGER_SCRIPT_PATH=
# wger 的 info-level 日志走 console.info → stdout 会破坏 MCP JSON-RPC；
# 默认设为 warn 把它压掉。排障时改 debug。可选值：debug / info / warn / error
# WGER_LOG_LEVEL=warn

# 首次冷启动余量（medical-mcp / wger-mcp 第一次拉/起包在国内代理下可能 30-60s）
# 命中本地缓存后实际只需 1-2s
MCP_STARTUP_TIMEOUT_SEC=90

# =========================
# 多模态 Vision（可选）
# =========================
# Provider 通过 OpenAI-compatible /chat/completions 统一调用；国内云上可填通义/智谱等兼容网关。
# disabled/mock 会安全降级，不影响纯文本评测。
VISION_ENABLED=true
VISION_PROVIDER=disabled
VISION_BASE_URL=
VISION_API_KEY=
VISION_MODEL=
VISION_TIMEOUT_SEC=60

# =========================
# 微信 iLink / ClawBot（可选）
# =========================
WECHAT_ILINK_BASE_URL=https://ilinkai.weixin.qq.com
WECHAT_BOT_TOKEN=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_POLL_TIMEOUT_SEC=30
WECHAT_WORKER_IDLE_SEC=1
# 若官方接口路径更新，只改下面这些变量，不需要改代码。
WECHAT_ENDPOINT_QRCODE=/v1/bot/qrcode
WECHAT_ENDPOINT_QRCODE_STATUS=/v1/bot/qrcode/status
WECHAT_ENDPOINT_UPDATES=/v1/messages/updates
WECHAT_ENDPOINT_SEND=/v1/messages/send
WECHAT_ENDPOINT_PUSH=/v1/messages/push
WECHAT_ENDPOINT_MEDIA=/v1/media/{media_id}

# =========================
# 提醒 / 备份 / 云部署（可选）
# =========================
REMINDER_POLL_INTERVAL_SEC=60
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_HOURS=24
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=
OSS_PREFIX=health-guide-backup

# Docker Compose 推荐覆盖为 /app/data 路径：
# SQLITE_DB_PATH=/app/data/checkpoints.db
# HEALTH_LOGS_DB_PATH=/app/data/health_logs.db
# OBSERVABILITY_DB_PATH=/app/data/observability.db
# PROFILE_STORE_PATH=/app/data/profile_store.json
# EPISODE_STORE_PATH=/app/data/episode_store.json
# SESSION_STORE_PATH=/app/data/session_store.json

# --- MCP server 本地安装目录（高级，仅 setup 脚本读取）---
# 默认装到 ~/.cache/mcp-servers/{usda-fdc,medical-mcp,wger-mcp}/
# 若想换位置（如装到项目内、SSD 路径等），在跑 setup 前 export 这些变量：
# MCP_USDA_DIR=/your/path/usda-fdc
# MCP_MEDICAL_DIR=/your/path/medical-mcp
# MCP_WGER_DIR=/your/path/wger-mcp
