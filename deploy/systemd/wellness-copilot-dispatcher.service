[Unit]
Description=Wellness Copilot reminder dispatcher
After=network-online.target
Wants=network-online.target

[Service]
WorkingDirectory=/opt/wellness-copilot
EnvironmentFile=/opt/wellness-copilot/.env
ExecStart=/usr/bin/python3 scripts/reminder_dispatcher.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
